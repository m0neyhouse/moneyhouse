# Sign & Pay — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores

# Senha do painel admin (escolha uma senha segura)
ADMIN_PASSWORD=sua_senha_aqui

# Access Token do MercadoPago (Production ou Sandbox)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# Secret para assinatura dos cookies JWT (string longa e aleatória)
JWT_SECRET=coloque_aqui_uma_string_longa_e_aleatoria_para_assinar_os_tokens

# URL base do site
# Local: http://localhost:3000
# Produção: https://seusite.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
